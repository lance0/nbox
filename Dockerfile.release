# Minimal runtime image for nbox.
#
# Expects a prebuilt static (musl) `nbox` binary in the build context — the
# release build produces `nbox-x86_64-unknown-linux-musl`; stage its `nbox`
# binary next to this file before `docker build`. This image is not a from-source
# build; it just wraps the binary with CA certificates for HTTPS to NetBox.
FROM alpine:3.20

RUN apk add --no-cache ca-certificates

COPY nbox /usr/local/bin/nbox

ENTRYPOINT ["nbox"]
